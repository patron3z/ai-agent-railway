# ─────────────────────────────────────────
# AI AGENT — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Sur Railway : Settings → Variables
# ─────────────────────────────────────────


# ── OBLIGATOIRE ──────────────────────────

# Clé API Anthropic → https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-


# ── RECHERCHE WEB ────────────────────────

# Serper API (Google Search) → https://serper.dev
# Sans cette clé : fallback DuckDuckGo (résultats limités)
SERPER_API_KEY=


# ── SÉCURITÉ ─────────────────────────────

# Clé secrète pour protéger vos endpoints API
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Envoyer dans le header : Authorization: Bearer <votre_clé>
# Laisser vide = pas d'authentification (déconseillé en prod)
API_SECRET_KEY=


# ── MODÈLE CLAUDE ────────────────────────

# Modèles disponibles :
#   claude-opus-4-6          → le plus puissant (recommandé)
#   claude-sonnet-4-6        → bon équilibre vitesse/qualité
#   claude-haiku-4-5-20251001 → le plus rapide et économique
MODEL=claude-opus-4-6

# Nombre max de tokens dans la réponse
MAX_TOKENS=4096

# Nombre max d'itérations de l'agent (boucle tool_use)
MAX_ITERATIONS=15


# ── SERVEUR ──────────────────────────────

# Railway injecte PORT automatiquement — ne pas modifier sur Railway
PORT=8000

# Environnement : development | production
ENVIRONMENT=production

# Origines autorisées pour CORS (séparées par virgule)
# Exemple : https://monapp.com,https://autre.com
# * = tout autoriser (déconseillé en prod)
ALLOWED_ORIGINS=*


# ── RATE LIMITING ────────────────────────

# Nombre max de requêtes par minute par IP
RATE_LIMIT_PER_MINUTE=20


# ── LOGGING ──────────────────────────────

# Niveau de log : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
